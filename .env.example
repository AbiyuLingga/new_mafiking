NODE_ENV=production
PORT=3000

# Wajib diisi — generate dengan: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Payment provider: qris (lokal) atau manual. v3 cleanup: duitku/midtrans/mutasiku sudah dihapus.
PAYMENT_PROVIDER=qris

# QRIS lokal tanpa payment gateway.
# Isi dengan string hasil scan QRIS statis merchant pribadi.
QRIS_STATIC_STRING=
QRIS_MERCHANT_NAME=MAFIKING
QRIS_EXPIRY_MINUTES=20
QRIS_SUFFIX_MIN=1
QRIS_SUFFIX_MAX=999
QRIS_ADMIN_WHATSAPP=
PAYMENT_WEBHOOK_SECRET=
# Mutasiku dihapus (plan_security_payment v3 cleanup). QRIS lokal via qris-mutasi adalah satu-satunya auto-verify.

# Clerk Google Sign-In
# Ambil dari Clerk Dashboard setelah membuat application dan mengaktifkan Google SSO.
# CLERK_SECRET_KEY jangan pernah dipakai di frontend.
CLERK_PUBLISHABLE_KEY=
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# Email verification (Gmail SMTP via App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=mafikingsolusitpb@gmail.com
SMTP_PASS=
MAIL_FROM=mafikingsolusitpb@gmail.com
MAIL_FROM_NAME=Mafiking
MAIL_DRY_RUN=false
PUBLIC_BASE_URL=https://mafiking.com

# Gemini API keys (isi sebanyak yang kamu punya, minimal GEMINI_KEY_1)
GEMINI_KEY_1=
GEMINI_KEY_2=
GEMINI_KEY_3=
GEMINI_KEY_4=
GEMINI_KEY_5=
GEMINI_KEY_6=
GEMINI_KEY_7=
GEMINI_KEY_8=
GEMINI_KEY_9=
GEMINI_KEY_10=

# Opsional: override urutan model OCR/evaluasi canvas (kosongkan = pakai default kode)
# GEMINI_MODELS=gemini-3.1-flash-lite

# Profile summary narrative memakai Gemma via Gemini API key.
GEMMA_PROFILE_MODEL=gemma-4-31b-it
# Opsional: comma-separated fallback model profile. Jika kosong, pakai GEMMA_PROFILE_MODEL/default.
# GEMMA_PROFILE_MODELS=gemma-4-31b-it

# ─── Multi-Provider Pool ──────────────────────────────────────
# Weighted random pool: Gemini (default 50%) + Groq (default 30%) + OpenRouter (default 20%) + cache + queue.
# Set ke false untuk disable pool dan pakai direct Gemini (legacy).
MAFIKING_POOL_ENABLED=true
MAFIKING_POOL_GEMINI_WEIGHT=0.5
MAFIKING_POOL_GROQ_WEIGHT=0.3
MAFIKING_POOL_OPENROUTER_WEIGHT=0.2
MAFIKING_POOL_MAX_CONCURRENT=5
MAFIKING_POOL_CACHE_TTL_MS=3600000

# Groq vision provider (model: meta-llama/llama-4-scout-17b-16e-instruct)
GROQ_API_KEY=


# Fast-path exact/equivalent answer override. Disable if false-positive issues appear.
MAFIKING_FAST_PATH_ENABLED=true

# DeepSeek — untuk import soal AI
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_MAX_TOKENS=12000
DEEPSEEK_TIMEOUT_MS=90000

# Set ke false untuk matikan auto-admin dari localhost
# LOCAL_ADMIN_MODE=false

# Canary-token paths (comma-separated). Any request that hits one of
# these paths is logged at high severity and returns 404. Use names
# that look attractive to attackers but do not collide with real routes.
# Example: CANARY_PATHS=/api/admin/dump-db,/api/admin/shell
# CANARY_PATHS=

# ============================================
# Auto-Verification Collector
# ============================================
# Enable/disable auto-verification (default: true setelah v3 cleanup)
# Set ke 'false' hanya untuk maintenance window atau rollback.
MUTATION_COLLECTOR_ENABLED=true

# Provider: 'qris_merchant' | 'mock' (default: qris_merchant untuk production)
MUTATION_PROVIDER=qris_merchant

# Default polling interval (ms). Self-healing collector adaptive: hot 3s / warm 10s / cold 60s.
MUTATION_POLL_INTERVAL_MS=10000

# Adaptive polling tier thresholds
MUTATION_POLL_HOT_INTERVAL_MS=3000
MUTATION_POLL_COLD_INTERVAL_MS=60000
MUTATION_ADAPTIVE_PENDING_THRESHOLD=1
MUTATION_ADAPTIVE_COLD_AFTER_MS=300000

# Max consecutive errors before circuit breaker trips
MUTATION_MAX_ERRORS=3

# Self-healing collector (default: true)
SELF_HEALING_COLLECTOR=true

# Feature flags (default: true, set 'false' untuk rollback cepat)
SSE_PAYMENT_PUSH=true
ADAPTIVE_POLLING=true
BULK_ADMIN=true
CONFIDENCE_MATCHING=true
PAYMENT_SUCCESS_EMAIL=true

# QRIS Merchant Dashboard credentials (for qris_merchant provider)
# Daftar di merchant.qris.online
QRIS_MERCHANT_EMAIL=
QRIS_MERCHANT_PASSWORD=

# Empty filter means no dashboard search text. Use only for targeted debugging.
QRIS_MUTATION_FILTER=
QRIS_MUTATION_LOOKBACK_DAYS=1
QRIS_MUTATION_TIME_ZONE=Asia/Jakarta
QRIS_MUTATION_DEBUG=false

# Directory for cookie storage (default: /tmp)
QRIS_COOKIE_DIR=/tmp

# Hash pepper for payer ID hashing and content hash
# Generate: openssl rand -hex 32
HASH_PEPPER=
