NODE_ENV=production
PORT=3000

# Wajib diisi — generate dengan: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Clerk Google Sign-In
# Ambil dari Clerk Dashboard setelah membuat application dan mengaktifkan Google SSO.
# CLERK_SECRET_KEY jangan pernah dipakai di frontend.
CLERK_PUBLISHABLE_KEY=
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# Gemini API keys (isi sebanyak yang kamu punya, minimal GEMINI_KEY_1)
GEMINI_KEY_1=
GEMINI_KEY_2=
GEMINI_KEY_3=
GEMINI_KEY_4=
GEMINI_KEY_5=
GEMINI_KEY_6=
GEMINI_KEY_7=
GEMINI_KEY_8=
GEMINI_KEY_9=
GEMINI_KEY_10=

# Opsional: override urutan model OCR/evaluasi canvas (kosongkan = pakai default kode)
# GEMINI_MODELS=gemini-3.1-flash-lite

# Profile summary narrative memakai Gemma via Gemini API key.
GEMMA_PROFILE_MODEL=gemma-4-31b-it
# Opsional: comma-separated fallback model profile. Jika kosong, pakai GEMMA_PROFILE_MODEL/default.
# GEMMA_PROFILE_MODELS=gemma-4-31b-it

# Legacy 9Router profile provider. Default production Mafiking tidak memakai ini.
# Set PROFILE_PROVIDER_ALLOW_9ROUTER=true hanya jika ingin override sementara ke 9Router.
AI_PROFILE_PROVIDER=gemma
PROFILE_PROVIDER_ALLOW_9ROUTER=false
NINEROUTER_BASE_URL=http://127.0.0.1:20128/v1
NINEROUTER_API_KEY=
# Fallback tunggal jika NINEROUTER_MODELS tidak diisi.
NINEROUTER_MODEL=kr/claude-haiku-4.5
# Round-robin hanya model yang sudah terbukti aktif.
NINEROUTER_MODELS=kr/auto,kr/claude-haiku-4.5,kr/deepseek-3.2,kr/qwen3-coder-next,kr/glm-5,kr/minimax-m2.5,kr/minimax-m2.1,ag/gemini-3-flash
NINEROUTER_MAX_TOKENS=1200
NINEROUTER_TIMEOUT_MS=60000

# DeepSeek — untuk import soal AI
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_MAX_TOKENS=12000
DEEPSEEK_TIMEOUT_MS=90000

# Set ke false untuk matikan auto-admin dari localhost
# LOCAL_ADMIN_MODE=false

# Canary-token paths (comma-separated). Any request that hits one of
# these paths is logged at high severity and returns 404. Use names
# that look attractive to attackers but do not collide with real routes.
# Example: CANARY_PATHS=/api/admin/dump-db,/api/admin/shell
# CANARY_PATHS=
